#!/bin/sh
# Skip in CI — dev dependencies (phpcs) are not installed there.
[ -n "$CI" ] && exit 0

# Auto-build JS/CSS assets when src/ files are staged.
# Adds the compiled assets/ back into the commit automatically.

if git diff --cached --name-only | grep -q '^src/'; then
  echo "src/ changes detected — running npm run build..."
  npm run build || { echo "npm run build failed. Commit aborted."; exit 1; }
  git add assets/
fi

# Run PHPCS on staged PHP files.
STAGED_PHP=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$' | grep -v '^vendor/' | grep -v '^node_modules/')
if [ -n "$STAGED_PHP" ]; then
  echo "PHP files staged — running PHPCS..."
  echo "$STAGED_PHP" | xargs ./vendor/bin/phpcs --standard=phpcs.xml.dist || {
    echo "PHPCS failed. Run: ./vendor/bin/phpcbf --standard=phpcs.xml.dist for auto-fixes."
    exit 1
  }
fi
